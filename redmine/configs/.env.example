# Redmine MCP configuration example
# Copy this file to .env and modify the corresponding values

# Redmine service settings
REDMINE_DOMAIN=http://localhost:3000
REDMINE_API_KEY=your_api_key_here

# MCP dedicated settings (to avoid conflicts with other projects)
REDMINE_MCP_TIMEOUT=30
REDMINE_MCP_LOG_LEVEL=INFO

# Backward compatible settings (used when dedicated variables are not set)
REDMINE_TIMEOUT=30
LOG_LEVEL=INFO
