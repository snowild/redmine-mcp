# Redmine MCP server environment variable configuration template
# Copy this file to .env and fill in actual values

# === Required configuration ===

# Redmine server domain (required)
# Example: https://redmine.example.com or http://localhost:3000
REDMINE_DOMAIN=https://your-redmine-domain.com

# Redmine API key (required)
# Obtain in Redmine personal settings > API access key
REDMINE_API_KEY=your_api_key_here

# === Optional configuration ===

# Dedicated variables (recommended to avoid conflicts with other projects)
# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL, default: INFO)
# Note: must be in uppercase format
REDMINE_MCP_LOG_LEVEL=INFO

# API request timeout (seconds, default: 30)
REDMINE_MCP_TIMEOUT=30

# === Backward compatible configuration ===
# The following variables are fallback options, dedicated variables above are recommended

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL, default: INFO)
# Note: must be in uppercase format, e.g. DEBUG not debug
# LOG_LEVEL=INFO

# API request timeout (seconds, used when REDMINE_MCP_TIMEOUT is not set)
REDMINE_TIMEOUT=30
